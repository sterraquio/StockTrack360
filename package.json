{
  "name": "stocktrack360-monorepo",
  "private": true,
  "packageManager": "pnpm@11.1.1+sha512.d1fdf5f73c617b64fa1a56a81c3c8dfe0e966e33a6010aa256b517ae77be21d93e05affc0de1a83b0e4f29d569f68b446ae8f068cd7247c0bb3df0fb4d7bdf9a",
  "scripts": {
    "dev": "pnpm --dir stock-track-360 dev",
    "dev:frontend": "pnpm --dir stock-track-360 dev",
    "dev:legacy": "pnpm --dir stock-track-360 dev",
    "dev:gateway": "pnpm --filter @stocktrack360/api-gateway dev",
    "dev:auth": "pnpm --filter @stocktrack360/auth-service dev",
    "dev:inventory": "pnpm --filter @stocktrack360/inventory-service dev",
    "dev:reporting-alerts": "pnpm --filter @stocktrack360/reporting-alerts-service dev",
    "dev:all": "pnpm --parallel --stream -r dev",
    "lint": "pnpm --dir stock-track-360 lint"
  }
}
